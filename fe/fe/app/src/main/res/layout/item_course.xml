<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#F2DFCE"
    app:strokeWidth="1.5dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Course Image (Duck Mascot) -->
        <ImageView
            android:id="@+id/imgCourse"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Course Title"
            android:textColor="#555555"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginStart="18dp"
            app:layout_constraintStart_toEndOf="@id/imgCourse"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Description -->
        <TextView
            android:id="@+id/txtDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Course description"
            android:textColor="#777777"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/txtTitle"
            app:layout_constraintStart_toStartOf="@id/txtTitle"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Details Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetail"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Course Details"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:textColor="#5A4028"
            android:layout_marginTop="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="16dp"
            app:backgroundTint="#F0D1B5"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/txtDesc"
            app:layout_constraintStart_toStartOf="@id/txtTitle"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Add Plus (+) Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="+"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="#DD9B53"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toTopOf="@id/btnDetail"
            app:layout_constraintBottom_toBottomOf="@id/btnDetail"
            app:layout_constraintStart_toEndOf="@id/btnDetail"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>